<!DOCTYPE html>
<html lang="es">
<head>
    <title>Películas</title>
    <style>body{font-family:Arial;padding:20px;} table{width:100%;border-collapse:collapse;margin-top:20px;} th,td{border:1px solid #ddd;padding:10px;} th{background:#2b2b2b;color:white;} .card{margin-bottom:20px;padding:20px;border:1px solid #ccc;}</style>
</head>
<body>
    <h1>Gestión de Películas</h1>
    
    <div class="card">
        <h3>Agregar Nueva Película</h3>
        <form action="/peliculas" method="POST">
            <input type="text" name="titulo" placeholder="Título" required>
            <input type="text" name="genero" placeholder="Género" required>
            <input type="number" name="duracion" placeholder="Duración (min)" required>
            <button type="submit" style="background:#28a745; color:white; border:none; padding:8px 15px; cursor:pointer;">Guardar</button>
        </form>
    </div>

    <table>
        <tr><th>ID</th><th>Título</th><th>Género</th><th>Duración</th><th>Acciones</th></tr>
        <% peliculas.forEach(p => { %>
        <tr>
            <td><%= p.id %></td><td><%= p.titulo %></td><td><%= p.genero %></td><td><%= p.duracion %> min</td>
            <td>
                <a href="/peliculas/<%= p.id %>/editar"><button style="background:#007bff; color:white; border:none; padding:5px 10px; cursor:pointer;">Editar</button></a>
                <form action="/peliculas/<%= p.id %>?_method=DELETE" method="POST" style="display:inline;">
                    <button type="submit" style="background:#dc3545; color:white; border:none; padding:5px 10px; cursor:pointer;">Eliminar</button>
                </form>
            </td>
        </tr>
        <% }) %>
    </table>
    <br><a href="/">Volver al inicio</a>
</body>
</html>