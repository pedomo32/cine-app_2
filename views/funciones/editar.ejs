<!DOCTYPE html>
<html lang="es">
<head>
    <title>Editar Función</title>
    <style>body{font-family:Arial;padding:20px;} .card{background:white;padding:20px;border-radius:8px;max-width:400px;border:1px solid #ddd;} input{display:block;width:90%;padding:10px;margin-bottom:15px;}</style>
</head>
<body>
    <h1>Editar Función</h1>
    <div class="card">
        <form action="/funciones/<%= funcion.id %>?_method=PUT" method="POST">
            <label>ID Película:</label>
            <input type="number" name="pelicula_id" value="<%= funcion.pelicula_id %>" required>
            
            <label>ID Sala:</label>
            <input type="number" name="sala_id" value="<%= funcion.sala_id %>" required>
            
            <label>Fecha y Hora:</label>
            <input type="datetime-local" name="fecha_hora" value="<%= funcion.fecha_formateada %>" required>
            
            <label>Precio:</label>
            <input type="number" step="0.01" name="precio" value="<%= funcion.precio %>" required>
            
            <button type="submit" style="background:#007bff; color:white; border:none; padding:10px 15px; font-weight:bold; cursor:pointer;">Actualizar Cambios</button>
            <a href="/funciones" style="margin-left: 15px; color:#555;">Cancelar</a>
        </form>
    </div>
</body>
</html>