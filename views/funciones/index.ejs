<!DOCTYPE html>
<html lang="es">
<head>
    <title>Funciones</title>
    <style>body{font-family:Arial;padding:20px;} table{width:100%;border-collapse:collapse;margin-top:20px;} th,td{border:1px solid #ddd;padding:10px;} th{background:#1a5276;color:white;} .card{margin-bottom:20px;padding:20px;border:1px solid #ccc;}</style>
</head>
<body>
    <h1>Gestión de Funciones</h1>
    
    <div class="card">
        <h3>Programar Nueva Función</h3>
        <form action="/funciones" method="POST">
            <input type="number" name="pelicula_id" placeholder="ID Película (Ej: 1)" required>
            <input type="number" name="sala_id" placeholder="ID Sala (Ej: 2)" required>
            <input type="datetime-local" name="fecha_hora" required>
            <input type="number" step="0.01" name="precio" placeholder="Precio" required>
            <button type="submit" style="background:#28a745; color:white; border:none; padding:8px 15px; cursor:pointer;">Guardar Función</button>
        </form>
    </div>

    <table>
        <tr><th>ID</th><th>Película</th><th>Sala</th><th>Fecha y Hora</th><th>Precio</th><th>Acciones</th></tr>
        <% funciones.forEach(f => { %>
        <tr>
            <td><%= f.id %></td><td><%= f.pelicula %></td><td><%= f.sala %></td>
            <td><%= f.fecha_hora %></td><td>$<%= f.precio %></td>
            <td>
                <a href="/funciones/<%= f.id %>/editar"><button style="background:#007bff; color:white; border:none; padding:5px 10px; cursor:pointer;">Editar</button></a>
                <form action="/funciones/<%= f.id %>?_method=DELETE" method="POST" style="display:inline;">
                    <button type="submit" style="background:#dc3545; color:white; border:none; padding:5px 10px; cursor:pointer;">Eliminar</button>
                </form>
            </td>
        </tr>
        <% }) %>
    </table>
    <br><a href="/">Volver al inicio</a>
</body>
</html>