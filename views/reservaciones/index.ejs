<!DOCTYPE html>
<html lang="es">
<head>
    <title>Reservaciones</title>
    <style>body{font-family:Arial;padding:20px;} table{width:100%;border-collapse:collapse;margin-top:20px;} th,td{border:1px solid #ddd;padding:10px;} th{background:#27ae60;color:white;} .card{margin-bottom:20px;padding:20px;border:1px solid #ccc;} input{padding:8px; margin-right:10px;}</style>
</head>
<body>
    <h1>Gestión de Reservaciones</h1>
    
    <div class="card">
        <h3>Registrar Nueva Reservación</h3>
        <form action="/reservaciones" method="POST">
            <input type="text" name="nombre_cliente" placeholder="Nombre del Cliente" required>
            <input type="datetime-local" name="fecha_reserva" required>
            <button type="submit" style="background:#2ecc71; color:white; border:none; padding:8px 15px; cursor:pointer; font-weight:bold;">Confirmar Reserva</button>
        </form>
    </div>

<table>
    <tr><th>ID</th><th>Cliente</th><th>Fecha y Hora</th><th>Acciones</th></tr>
    <% reservaciones.forEach(r => { %>
    <tr>
        <td><%= r.id %></td>
        <td><%= r.nombre_cliente %></td>
        
        <td>
            <%= (r.fecha_reserva && !isNaN(new Date(r.fecha_reserva))) ? new Date(r.fecha_reserva).toLocaleString() : 'Fecha no definida' %>
        </td>
        
        <td>
            <a href="/reservaciones/<%= r.id %>/editar"><button style="background:#007bff; color:white; border:none; padding:5px 10px; cursor:pointer;">Editar</button></a>
            <form action="/reservaciones/<%= r.id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit" style="background:#dc3545; color:white; border:none; padding:5px 10px; cursor:pointer;">Eliminar</button>
            </form>
        </td>
    </tr>
    <% }) %>
</table>
    <br><a href="/">Volver al inicio</a>
</body>
</html>