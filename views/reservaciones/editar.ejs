<!DOCTYPE html>
<html lang="es">
<head>
    <title>Editar Reservación</title>
    <style>body{font-family:Arial;padding:20px;} .card{background:white;padding:20px;border-radius:8px;max-width:400px;border:1px solid #ddd;} input{display:block;width:90%;padding:10px;margin-bottom:15px;}</style>
</head>
<body>
    <h1>Editar Reservación</h1>
    <div class="card">
        <form action="/reservaciones/<%= reservacion.id %>?_method=PUT" method="POST">
            <label>Nombre del Cliente:</label>
            <input type="text" name="nombre_cliente" value="<%= reservacion.nombre_cliente %>" required>
            
            <label>Fecha y Hora de la Reserva:</label>
            <input type="datetime-local" name="fecha_reserva" value="<%= reservacion.fecha_formateada %>" required>
            
            <button type="submit" style="background:#007bff; color:white; border:none; padding:10px 15px; font-weight:bold; cursor:pointer;">Actualizar Cambios</button>
            <a href="/reservaciones" style="margin-left: 15px; color:#555;">Cancelar</a>
        </form>
    </div>
</body>
</html>